{
  "name": "suno-downloader",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n \"server,vite\" -c \"cyan,magenta\" \"node server.js\" \"vite\"",
    "server": "node server.js",
    "build:og": "node scripts/og/build-og.mjs",
    "build": "npm run build:og && vite build",
    "start": "NODE_ENV=production node server.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "express": "^4.18.2",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.0.8"
  }
}
